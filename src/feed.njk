---
permalink: /feed.xml
eleventyExcludeFromCollections: true
---
<?xml version="1.0" encoding="utf-8"?>
<feed xmlns="http://www.w3.org/2005/Atom">
  <title>{{ site.title }}</title>
  <subtitle>{{ site.description }}</subtitle>
  <link href="{{ site.url }}feed.xml" rel="self" type="application/atom+xml"/>
  <link href="{{ site.url }}" rel="alternate" type="text/html"/>
  <updated>{{ collections.posts[0].date | dateToRfc3339 }}</updated>
  <id>{{ site.url }}</id>
  <author>
    <name>{{ site.author }}</name>
  </author>
  {%- for post in collections.posts | head(20) %}
  <entry>
    <title>{{ post.data.title }}</title>
    <link href="{{ site.url }}{{ post.url | removeLeadingSlash }}" rel="alternate" type="text/html"/>
    <published>{{ post.date | dateToRfc3339 }}</published>
    <updated>{{ post.date | dateToRfc3339 }}</updated>
    <id>{{ site.url }}{{ post.url | removeLeadingSlash }}</id>
    <content type="html">{{ post.templateContent | htmlToAbsoluteUrls(site.url + post.url) }}</content>
    {%- for tag in post.data.tags %}
    <category term="{{ tag }}"/>
    {%- endfor %}
  </entry>
  {%- endfor %}
</feed>
