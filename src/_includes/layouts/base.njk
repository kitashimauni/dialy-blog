<!DOCTYPE html>
<html lang="{{ site.lang }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% block pageTitle %}{{ title }}{% endblock %} | {{ site.title }}</title>
  {%- set metaDescription = description if description else site.description -%}
  <meta name="description" content="{{ metaDescription }}">
  <meta name="author" content="{{ site.author }}">
  <link rel="canonical" href="{{ site.url }}{{ page.url | removeLeadingSlash }}">

  <!-- OGP -->
  <meta property="og:title" content="{{ title }} | {{ site.title }}">
  <meta property="og:description" content="{{ metaDescription }}">
  <meta property="og:type" content="{% if layout == 'layouts/posts/base.njk' %}article{% else %}website{% endif %}">
  <meta property="og:url" content="{{ site.url }}{{ page.url | removeLeadingSlash }}">
  <meta property="og:site_name" content="{{ site.title }}">
  <meta property="og:locale" content="ja_JP">

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary">
  <meta name="twitter:title" content="{{ title }} | {{ site.title }}">
  <meta name="twitter:description" content="{{ metaDescription }}">

  <!-- RSS -->
  <link rel="alternate" type="application/atom+xml" title="{{ site.title }}" href="{{ site.url }}feed.xml">

  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <div class="page-wrapper">
    {% include 'partials/header.njk' %}

    <div class="content-area">
      <main>
        {% block content %}
          {{ content | safe }}
        {% endblock %}
      </main>

      {% include 'partials/sidebar.njk' %}
    </div>

    <div class="counter-bar">
      <span>あなたは</span>
      <a href="/posts/20260228/access-counter/"><img src="https://counter.n-island.dev/@blog?name=blog&theme=random&padding=7&offset=0&align=top&scale=1&pixelated=1&darkmode=0" alt="アクセスカウンター"></a>
      <span>人目の訪問者です！</span>
    </div>

    {% include 'partials/footer.njk' %}
  </div>
</body>
</html>
